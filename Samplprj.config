          "includeAllDebuggingInformation": true
        },
        "miscellaneousOptions": {
          "codeVersionNumber": 100
        }
      },
      "environment": {
        "CODE_PREFIX": [
          ".\\object"
        ],
        "COPYPATH": [
          ".\\screen",
          ".\\copylib",
          ".\\report",
          ".\\resource",
          ".\\fd",
          "..",
          "..\\def",
          "%layoutdir%",
