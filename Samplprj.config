        "FILE_PREFIX": [
          ".\\data"
        ],
        "variables": {
          "RUNNAME": "Wrun32.exe",
          "COMPILERNAME": "Ccbl32.exe",
          "ACUPATH": "%acudir%\\bin",
          "THINNAME": "AcuThin.exe",
          "CLASSPATHDIR": "%acudir%\\lib",
          "XUIJAR": "AcuXUI.jar"
